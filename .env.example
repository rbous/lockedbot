# ── Discord ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here

# ── Google Gemini AI (optional — enables the /ai chat feature) ───────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── CloudConvert (optional — enables file-conversion via AI) ─────────────────
CLOUDCONVERT_API_KEY=your_cloudconvert_api_key_here

# ── Google Calendar (required for calendar-aware check-ins) ──────────────────
#
# Option A: path to a service-account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
#
# Option B: paste the JSON content directly (one line, properly escaped)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Setup guide:
#  1. Create a project at https://console.cloud.google.com/
#  2. Enable the "Google Calendar API".
#  3. Create a Service Account under APIs & Services > Credentials.
#  4. Download the JSON key file.
#  5. Share your Google Calendar with the service-account e-mail address
#     (e.g. my-bot@my-project.iam.gserviceaccount.com) — grant Reader access.
#  6. Run /tracker setup in Discord and set the Calendar ID.

# ── Bot debug / dev ──────────────────────────────────────────────────────────
DEBUG_MODE=false
DEBUG_GUILD_IDS=your_guild_id_for_testing,another_guild_id
